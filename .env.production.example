# Copia come .env sul server: cp .env.production.example .env
# Genera segreti: node scripts/generate-secrets.js

NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# PostgreSQL (docker compose in deploy/)
DATABASE_URL="postgresql://omeita:POSTGRES_PASSWORD@127.0.0.1:5432/omeita?schema=public"
POSTGRES_PASSWORD="genera-con-scripts-generate-secrets.js"

# Sicurezza — CAMBIA TUTTO
JWT_SECRET="genera-stringa-lunga-casuale"
ADMIN_EMAIL="admin@tuodominio.tech"
ADMIN_PASSWORD="password-admin-sicura"

# Dominio pubblico (senza slash finale)
NEXT_PUBLIC_APP_URL="https://tuodominio.tech"
NEXT_PUBLIC_SOCKET_URL="https://tuodominio.tech"

# Google OAuth — aggiungi redirect URI produzione in Google Console
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (opzionale)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# TURN WebRTC — stesso valore di static-auth-secret in coturn
NEXT_PUBLIC_TURN_URL="turn:tuodominio.tech:3478"
NEXT_PUBLIC_TURN_USERNAME="omeita"
NEXT_PUBLIC_TURN_CREDENTIAL="stesso-TURN_SECRET-di-coturn"
